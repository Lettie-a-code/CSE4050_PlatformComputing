@model CSE4050_SignIn.ViewModels.LoginViewModel
<link rel="stylesheet" href="~/css/login.css" />
<div class="login">
    <h2>Login</h2>
    <form asp-action="Login" method="post" class="login-form">
        <input asp-for="Email" placeholder="Please enter your email" />
        <span asp-validation-for="Email"></span>
        <input asp-for="Password" type="password" placeholder="Please
enter your password" />
        <span asp-validation-for="Password"></span>
        <button type="submit">Login</button>
        @foreach (var err in ViewData.ModelState.Values.SelectMany(v
                => v.Errors))
        {
            <div>@err.ErrorMessage</div>
        }
    </form>
</div>
